{
  "name": "xmum-scheduler",
  "version": "1.0.0-alpha.1",
  "description": "Local-first XMUM student scheduler and knowledge workspace",
  "private": true,
  "bin": "server.mjs",
  "pkg": {
    "assets": [
      "dist/**/*",
      "package.json"
    ],
    "scripts": false,
    "targets": [
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-win-x64"
    ],
    "outputPath": "release"
  },
  "scripts": {
    "dev": "node dev.mjs",
    "dev:web": "vite --host 0.0.0.0",
    "api": "node server.mjs",
    "build": "tsc && vite build",
    "start": "node server.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "package": "pkg ."
  },
  "keywords": [
    "scheduler",
    "xmum",
    "student"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dicebear/glass": "^9.4.2",
    "@milkdown/core": "^7.20.0",
    "@milkdown/crepe": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@toast-ui/calendar": "^2.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}

{
  "name": "xmum-scheduler",
  "version": "1.0.0",
  "description": "Native desktop XMUM student scheduler and knowledge workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "tauri:build:macos": "tauri build --target x86_64-apple-darwin && tauri build --target aarch64-apple-darwin",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc"
  },
  "keywords": [
    "scheduler",
    "xmum",
    "student",
    "desktop",
    "tauri"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dicebear/glass": "^9.4.2",
    "@milkdown/core": "^7.20.0",
    "@milkdown/crepe": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@toast-ui/calendar": "^2.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}